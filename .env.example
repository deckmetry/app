# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
NEXT_PUBLIC_SUPABASE_SECRET_KEY=sb_secret_your-key-here
# Server-only — never expose to client
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Stripe
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-key-here
# STRIPE_SECRET_KEY=sk_test_your-key-here
STRIPE_WEBHOOK_SECRET=whsec_your-secret-here

STRIPE_PUBLISHABLE_KEY=pk_test_your-key-here
STRIPE_MCP_KEY=ek_test_your-key-here
STRIPE_SECRET_KEY=sk_test_your-key-here

# Homeowner one-time payments
STRIPE_HOMEOWNER_BOM_PRICE_ID=price_xxx          # $27 — BOM Generation
STRIPE_HOMEOWNER_REVIEW_PRICE_ID=price_xxx        # $97 — Pro Review
STRIPE_HOMEOWNER_PERMIT_PRICE_ID=price_xxx        # $197 — Permit-Ready Design
STRIPE_HOMEOWNER_3D_PRICE_ID=price_xxx            # $1,597 — 3D Design

# Contractor subscriptions
STRIPE_CONTRACTOR_SOLO_PRICE_ID=price_xxx         # $99/mo — Solo
STRIPE_CONTRACTOR_TEAM_BASE_PRICE_ID=price_xxx    # $149/mo — Teams base
STRIPE_CONTRACTOR_TEAM_SEAT_PRICE_ID=price_xxx    # $20/mo — Teams per-seat

# Supplier subscriptions
STRIPE_SUPPLIER_PLATFORM_PRICE_ID=price_xxx       # $697/mo — Platform base
STRIPE_SUPPLIER_SEAT_PRICE_ID=price_xxx           # $20/mo — per-seat
STRIPE_SUPPLIER_SETUP_PRICE_ID=price_xxx          # $7,500 one-time setup fee

# Resend
RESEND_API_KEY=re_your-key-here

# Inngest
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# Epicor (Phase 4 — set to "live" to use real Epicor, otherwise mock)
# EPICOR_MODE=mock

# Google Maps (Places Autocomplete on address fields)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-api-key-here

# App
NEXT_PUBLIC_APP_URL=https://deckmetry-app.vercel.app
